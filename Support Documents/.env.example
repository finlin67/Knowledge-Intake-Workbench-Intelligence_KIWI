# Optional parent-level environment hints for local development.
# start_kiwi.bat sets web/backend connection automatically.

# Force stable backend mode (no autoreload): 1 = enabled
# KIWI_STABLE_BACKEND=0

# Web API base (normally set by start_kiwi.bat)
# NEXT_PUBLIC_KIWI_API_BASE=http://127.0.0.1:8000

# Optional local Ollama URL used by backend tooling
# OLLAMA_BASE_URL=http://127.0.0.1:11434
