# Node / Next.js
**/node_modules/
**/.next/

# Build outputs
**/dist/
**/build/
**/out/

# Environment files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Python virtualenv and caches
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.cache/
**/*.egg-info/
.coverage
**/.coverage
htmlcov/
**/htmlcov/

# Logs
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local databases
*.db
*.sqlite
*.sqlite3
**/data/*.db
**/data/*.sqlite
**/data/*.sqlite3

# Local exports and large user data
exports/
**/exports/
sample_exports/generated/
sample_batches/uploads/

# Temp/editor files
*.tmp
*.temp
*.swp
*.swo
Thumbs.db
.DS_Store

# Keep sample placeholders tracked
!sample_batches/.gitkeep
!sample_exports/.gitkeep
