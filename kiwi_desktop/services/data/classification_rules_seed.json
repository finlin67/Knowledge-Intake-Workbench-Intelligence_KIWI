  "RULE_CONFIDENCE": {
    "force_rule":    0.96,
    "negative_rule": 0.95,
    "company_map":   0.90,
    "project_map":   0.85,
    "pattern":       0.75,
    "ollama":        0.72,
    "fallback":      0.40
  },

  "RISKY_KEYWORDS": ["doc", "docs", "file", "files", "note", "notes", "data", "misc"],

  "BROAD_KEYWORDS": ["project", "projects", "brief", "customer", "doc", "docs", "data", "note", "notes", "file", "files"],

  "broad_match_force_review": true,

  "enable_ollama": false,
  "ollama_model": "qwen2.5",
  "ai_provider": "ollama",
  "api_key": "",
  "cloud_model": "gpt-4o-mini",
  "ai_mode": "ai_only_unclassified",

  "auto_assign_workspace": true,
  "duplicate_filename_policy": "rename",

  "chunk_target_size": 220,
  "minimum_chunk_size": 120,

  "relevance_min_score": 1,
  "small_file_char_threshold": 260,
  "preflight_wiki_share_cap": 0.25,

  "confidence_threshold": 0.65,
  "low_confidence_threshold": 0.65,
  "review_confidence_threshold": 0.65
